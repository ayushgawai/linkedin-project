# =============================================================================
# LinkedInClone environment variables.
# Copy to `.env` in the repo root before running `docker compose`.
# All defaults here are suitable for a local dev / benchmark run.
# =============================================================================

# ---- Global -----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---- MySQL ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASS=linkedin
DB_NAME=linkedinclone
DB_POOL_MAX=20
# Host-side port used by docker-compose (change if 3306 is taken on your Mac).
DB_PORT_HOST=3307

# ---- MongoDB ----------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=linkedinclone
MONGO_PORT_HOST=27017

# ---- Redis ------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=true
REDIS_PORT_HOST=6379

# Cache TTLs (seconds).
# Entity TTL = single-object reads (member:<id>, job:<id>).
# Search TTL = filter-based list queries (member:search:*, job:search:*).
# Analytics TTL = expensive Mongo aggregations (analytics:*).
CACHE_TTL_ENTITY_SEC=300
CACHE_TTL_SEARCH_SEC=60
ANALYTICS_CACHE_TTL_SEC=60
OTHER_TECHNIQUES_ENABLED=true

# ---- Kafka ------------------------------------------------------------------
# From the host machine use localhost:9092; from inside the compose network
# use kafka:29092 — docker-compose.yml wires the correct value per service.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=linkedinclone
KAFKA_ENABLED=true
KAFKA_PORT_HOST=9092
ZOOKEEPER_PORT_HOST=2181

# ---- Service ports (host side) ---------------------------------------------
PROFILE_PORT_HOST=8001
JOB_PORT_HOST=8002
APPLICATION_PORT_HOST=8003
MESSAGING_PORT_HOST=8004
CONNECTION_PORT_HOST=8005
ANALYTICS_PORT_HOST=8006
AI_PORT_HOST=8007

# ---- Python services (host dev): bridge to analytics ingest -----------------
ANALYTICS_SERVICE_URL=http://localhost:8006

# ---- AI Agent (Member 3 / FastAPI :8007) -------------------------------------
# In Docker, compose sets service URLs automatically. For local uvicorn only, use localhost.
# OPENAI_API_KEY=sk-...   # optional; skills fall back to templates if unset
OPENAI_API_KEY=
KAFKA_CONSUMER_GROUP=ai-supervisor-group

# ---- Benchmark knobs (used by Phase 4/5) -----------------------------------
# Override these to run larger/faster benchmarks without editing scripts.
BENCH_SEED_RECRUITERS=200
BENCH_SEED_MEMBERS=10000
BENCH_SEED_JOBS=2000
BENCH_SEED_APPS=25000
BENCH_SEED_CONNECTIONS=30000
BENCH_SEED_EVENTS=200000
BENCH_SEED_BATCH=1000
# Token required in the X-Bench-Token header for /benchmark/* endpoints.
BENCH_ADMIN_TOKEN=dev-only
BENCH_JMETER_THREADS=50
BENCH_JMETER_RAMP=10
BENCH_JMETER_DURATION=120

