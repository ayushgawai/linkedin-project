# ----------------------------------------------------------------------------
# AI Agent Service — environment configuration
# ----------------------------------------------------------------------------
# Two modes are supported:
#
#   1. DEMO / DEV MODE        USE_MOCK_SERVICES=true
#      All upstream calls (Profile, Job, Application, Messaging) return
#      deterministic in-process mock data. The other team services do NOT
#      need to be running. This is the default and is what the AI test
#      harness uses.
#
#   2. REAL INTEGRATION MODE  USE_MOCK_SERVICES=false
#      All upstream calls go out over HTTP using the *_SERVICE_URL values
#      below. Every URL must be set or the service will refuse to start
#      (see Settings.validate_for_real_mode in src/config.py).
# ----------------------------------------------------------------------------

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=linkedinclone

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai-supervisor-group
KAFKA_TOPIC_REQUESTS=ai.requests
KAFKA_TOPIC_RESULTS=ai.results

# Upstream service URLs — REQUIRED when USE_MOCK_SERVICES=false.
# These are read by src/service_clients.py for every outbound HTTP call.
PROFILE_SERVICE_URL=http://localhost:8001
JOB_SERVICE_URL=http://localhost:8002
APPLICATION_SERVICE_URL=http://localhost:8003
MESSAGING_SERVICE_URL=http://localhost:8004

# Toggle between mock and real upstream services.
#   true  — use deterministic in-process mocks (default for demo + tests)
#   false — call the real Profile/Job/Application/Messaging services over HTTP
USE_MOCK_SERVICES=true

# OpenAI (optional). If blank, all skills use deterministic / template logic.
OPENAI_API_KEY=

# Career coach narrative (uses OPENAI_API_KEY; set COACH_LLM_ENABLED=false to force templates only)
COACH_LLM_ENABLED=true
COACH_LLM_MODEL=gpt-4o-mini
COACH_LLM_TIMEOUT_SEC=45

# Server
SERVICE_PORT=8007
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000
