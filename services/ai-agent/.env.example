# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=linkedinclone

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=ai-supervisor-group
KAFKA_TOPIC_REQUESTS=ai.requests
KAFKA_TOPIC_RESULTS=ai.results

# Service URLs (other microservices)
PROFILE_SERVICE_URL=http://localhost:8001
JOB_SERVICE_URL=http://localhost:8002
APPLICATION_SERVICE_URL=http://localhost:8003
MESSAGING_SERVICE_URL=http://localhost:8004

# Mocking (set to false when real services are available)
USE_MOCK_SERVICES=true

# OpenAI (optional — if blank, skills use deterministic/template logic)
OPENAI_API_KEY=

# Career coach narrative (uses OPENAI_API_KEY; set COACH_LLM_ENABLED=false to force templates only)
COACH_LLM_ENABLED=true
COACH_LLM_MODEL=gpt-4o-mini
COACH_LLM_TIMEOUT_SEC=45

# Server
SERVICE_PORT=8007
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000
