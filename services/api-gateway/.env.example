# Copy to .env in this directory when running the gateway on your machine (not inside Docker):
#   cd services/api-gateway && cp .env.example .env && npm start
#
# Backend services must be listening on these host ports (default docker-compose publishes them).
# Frontend should use the same port as PORT below for VITE_API_BASE_URL (e.g. http://127.0.0.1:8011).

PORT=8011

PROFILE_URL=http://127.0.0.1:8001
JOB_URL=http://127.0.0.1:8002
APPLICATION_URL=http://127.0.0.1:8003
MESSAGING_URL=http://127.0.0.1:8004
CONNECTION_URL=http://127.0.0.1:8005
ANALYTICS_URL=http://127.0.0.1:8006
AI_URL=http://127.0.0.1:8007
POSTS_URL=http://127.0.0.1:8008

S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=linkedinclone-media
